# Connection string for the admin database (the one used to create/destroy databases)
# The user provided should have permissions to create databases and assign privileges.
# Only needed if you are using this system to create the databases
ADMIN_DB=
# URI string for the user's database (the one being migrated)
# (eg `postgresql://user:pass@server:port/db`)
PROJECT_DB=
# Name of the file that holds the base schema for the Project Database
SCHEMA_FILE=./tests/schema.sql
# Name of the file that will be written to when dumping pure data
DATA_FILE=./tests/data.sql
# Name of the file that will be written to when dumping both schema and data
SCHEMA_DATA_FILE=./tests/schema-data.sql
# Name of the table that tracks which migrations have and have not been applied
MIGRATION_TABLE=sl_migration
# Location of the migration files
MIGRATION_FOLDER=./tests/migrations

